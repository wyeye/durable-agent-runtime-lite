NODE_ENV=development
APP_ENV=local
APP_VERSION=0.8.0
BUILD_SHA=unknown
BUILD_TIME=unknown
HOST=0.0.0.0
PORT=
DATABASE_URL=postgres://dar:dar_local_password@localhost:15432/durable_agent_runtime
VALKEY_URL=redis://localhost:16380
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
MODEL_GATEWAY_BASE_URL=http://localhost:4100
MODEL_GATEWAY_API_KEY=dev-only-placeholder
MODEL_GATEWAY_MODEL=dar-local-model
MODEL_GATEWAY_PROFILE_ID=local-dev
MODEL_GATEWAY_MODE=disabled
MODEL_GATEWAY_PROTOCOL=dar_generate
MODEL_GATEWAY_TIMEOUT_MS=30000
MODEL_GATEWAY_MAX_RETRIES=1
MODEL_GATEWAY_MAX_RESPONSE_BYTES=1000000
MODEL_CALL_LEDGER_MAX_RESPONSE_BYTES=1048576
MODEL_GATEWAY_ALLOW_INSECURE_HTTP=true
MODEL_GATEWAY_IDEMPOTENCY_HEADER=Idempotency-Key
MODEL_GATEWAY_USER_AGENT=durable-agent-runtime-lite/runtime-worker
SEED_LOCAL_OLLAMA_MODEL_POLICY=false
PI_AGENT_MODE=disabled
PI_CONTEXT_MAX_BYTES=262144
PI_SEGMENT_TIMEOUT_MS=120000
PI_MAX_SEGMENTS_BEFORE_CONTINUE_AS_NEW=20
TOOL_GATEWAY_BASE_URL=http://localhost:3003
TOOL_GATEWAY_URL=http://localhost:3003
RUNTIME_API_URL=http://localhost:3001
RUNTIME_API_AUTH_MODE=disabled
JWT_ISSUER=http://localhost:3000
JWT_AUDIENCE=durable-agent-runtime-lite
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
CONTROL_PLANE_PORT=3000
RUNTIME_API_PORT=3001
RUNTIME_WORKER_PORT=3002
TOOL_GATEWAY_PORT=3003
RUNTIME_WORKER_MODE=mock
RUNTIME_API_WORKFLOW_STARTER=mock
RUNTIME_API_ROUTE_SOURCE=memory
TOOL_GATEWAY_REGISTRY_SOURCE=memory
TOOL_GATEWAY_AUTH_MODE=disabled
TENANT_RUNTIME_POLICY_MODE=optional
TENANT_POLICY_CACHE_TTL_MS=5000
TENANT_ADMISSION_RECONCILE_ENABLED=false
TENANT_ADMISSION_STALE_AFTER_MS=300000
TENANT_ADMISSION_MAX_RECONCILE_BATCH=50
EVALUATION_WORKER_ENABLED=false
EVALUATION_TASK_QUEUE=evaluation-worker-main
EVALUATION_MAX_CONCURRENT_RUNS=1
EVALUATION_MAX_CONCURRENT_CASES=2
EVALUATION_CASE_TIMEOUT_MS=120000
EVALUATION_GATE_MODE=advisory
EVALUATION_OUTPUT_MAX_BYTES=1000000
EVALUATION_EVIDENCE_MAX_BYTES=2000000
EVALUATION_REGEX_TIMEOUT_MS=250
SEED_EVALUATION_DATASETS=false
TOOL_GATEWAY_DEBUG_ENDPOINTS_ENABLED=false

# Development placeholders only. Production rejects the replace-with-* values,
# local-dev-* values, identical worker/control-plane tokens, and tokens shorter
# than the service-token minimum. Inject production values from a secret manager
# or environment, never from an image.
TOOL_GATEWAY_RUNTIME_WORKER_TOKEN=replace-with-runtime-worker-service-token
TOOL_GATEWAY_CONTROL_PLANE_TOKEN=replace-with-control-plane-service-token
RUNTIME_WORKER_TOOL_GATEWAY_TOKEN=replace-with-runtime-worker-service-token
CONTROL_PLANE_TOOL_GATEWAY_TOKEN=replace-with-control-plane-service-token
CONTROL_PLANE_AUTH_MODE=header
CONTROL_PLANE_SWAGGER_ENABLED=true
CONTROL_PLANE_STATIC_ENABLED=false

# Docker Compose host ports
POSTGRES_HOST_PORT=15432
VALKEY_HOST_PORT=16380
TEMPORAL_HOST_PORT=7233
TEMPORAL_UI_HOST_PORT=8233
RUNTIME_API_HOST_PORT=3000
CONTROL_PLANE_HOST_PORT=3100
TOOL_GATEWAY_HOST_PORT=3200
RUNTIME_WORKER_HOST_PORT=3300
MOCK_SERVER_HOST_PORT=4100
