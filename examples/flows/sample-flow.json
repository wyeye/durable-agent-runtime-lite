{
  "flow_id": "sample_flow",
  "version": 1,
  "name": "MVP sample flow",
  "runtime": {
    "workflow_type": "ConfigDrivenWorkflow",
    "task_queue": "runtime-worker-main"
  },
  "steps": [
    { "id": "input_normalize", "type": "activity", "activity": "input.normalize" },
    {
      "id": "knowledge_search",
      "type": "tool",
      "tool": "knowledge.search",
      "input": {
        "query": "${input.text}"
      }
    },
    { "id": "agent_plan", "type": "agent", "agent_id": "sample_agent" },
    {
      "id": "record_write",
      "type": "tool",
      "name": "record.write.mock preview -> human_confirm -> commit",
      "tool": "record.write.mock",
      "mode": "preview_commit",
      "risk_level": "L3",
      "input": {
        "record": "${state.steps.knowledge_search.result}"
      }
    }
  ]
}
