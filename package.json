{
  "name": "durable-agent-runtime-lite",
  "version": "0.1.5",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:infra": "docker compose -f infra/docker-compose.yml up -d",
    "dev:infra:down": "docker compose -f infra/docker-compose.yml down",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck && tsc -p tsconfig.scripts.json",
    "test": "turbo run test && vitest run --config vitest.root.config.ts --passWithNoTests",
    "test:temporal-replay": "vitest run tests/temporal-replay --config vitest.root.config.ts",
    "test:e2e": "vitest run tests/e2e --passWithNoTests",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:migrate": "tsx db/migrate.ts",
    "seed:examples": "tsx scripts/seed-examples.ts",
    "smoke:db-registry": "tsx scripts/smoke-db-registry.ts",
    "smoke:temporal-db-e2e": "tsx scripts/smoke-temporal-db-e2e.ts",
    "smoke:control-plane-api-e2e": "tsx scripts/smoke-control-plane-api-e2e.ts",
    "smoke:control-plane-ui-e2e": "tsx scripts/smoke-control-plane-ui-e2e.ts",
    "smoke:pi-readonly-e2e": "PI_SMOKE_SCENARIO=readonly_tool PI_SMOKE_MODE=deterministic tsx scripts/smoke-pi-e2e.ts",
    "smoke:pi-l3-e2e": "PI_SMOKE_SCENARIO=l3_tool PI_SMOKE_MODE=deterministic tsx scripts/smoke-pi-e2e.ts",
    "smoke:pi-user-input-e2e": "PI_SMOKE_SCENARIO=user_input PI_SMOKE_MODE=deterministic tsx scripts/smoke-pi-e2e.ts",
    "smoke:pi-handoff-e2e": "PI_SMOKE_SCENARIO=handoff PI_SMOKE_MODE=deterministic tsx scripts/smoke-pi-e2e.ts",
    "smoke:pi-restart-resume-e2e": "PI_SMOKE_SCENARIO=restart_resume PI_SMOKE_MODE=deterministic tsx scripts/smoke-pi-e2e.ts",
    "smoke:pi-worker-crash-resume-e2e": "PI_SMOKE_MODE=deterministic tsx scripts/smoke-pi-worker-crash-resume-e2e.ts",
    "smoke:pi-model-gateway-e2e": "PI_SMOKE_SCENARIO=model_gateway PI_SMOKE_MODE=model_gateway tsx scripts/smoke-pi-e2e.ts",
    "temporal:export-replay-fixtures": "tsx scripts/export-temporal-replay-fixtures.ts"
  },
  "devDependencies": {
    "@dar/config": "workspace:*",
    "@dar/contracts": "workspace:*",
    "@dar/db": "workspace:*",
    "@temporalio/client": "^1.11.0",
    "@temporalio/worker": "^1.11.0",
    "@eslint/js": "^9.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.0.0",
    "eslint": "^9.0.0",
    "pg": "^8.0.0",
    "pnpm": "10.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "turbo": "^2.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
