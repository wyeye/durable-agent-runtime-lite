{
  "name": "durable-agent-runtime-lite",
  "version": "0.1.5",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:infra": "docker compose -f infra/docker-compose.yml up -d",
    "dev:infra:down": "docker compose -f infra/docker-compose.yml down",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "vitest run tests/e2e --passWithNoTests",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:migrate": "tsx db/migrate.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "turbo": "^2.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0",
    "@types/pg": "^8.0.0",
    "pg": "^8.0.0"
  }
}
