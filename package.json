{
  "name": "durable-agent-runtime-lite",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:infra": "pnpm dar dev up",
    "dev:infra:down": "pnpm dar dev down",
    "dar": "tsx devtools/repo-cli/src/cli.ts",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck && tsc -p tsconfig.scripts.json",
    "test": "turbo run test && vitest run --config vitest.root.config.ts --passWithNoTests",
    "test:temporal-replay": "vitest run tests/temporal-replay --config vitest.root.config.ts",
    "version:check": "pnpm dar check version",
    "i18n:check": "pnpm dar check i18n",
    "visual-config:check": "pnpm dar check visual-config",
    "docs:check": "pnpm dar check docs",
    "mocks:check": "pnpm dar check mocks",
    "test:e2e": "vitest run tests/e2e --passWithNoTests",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:migrate": "pnpm dar db migrate",
    "seed:examples": "pnpm dar db seed",
    "admission:reconcile": "pnpm dar ops reconcile-admissions",
    "smoke": "pnpm dar smoke",
    "smoke:core": "pnpm dar smoke suite core",
    "smoke:agent": "pnpm dar smoke suite agent",
    "smoke:governance": "pnpm dar smoke suite governance",
    "smoke:ui": "pnpm dar smoke suite ui",
    "smoke:real": "pnpm dar smoke suite real",
    "ollama:probe": "tsx devtools/repo-cli/src/scripts/probe-ollama-model.ts",
    "runtime:assert-containerized": "tsx devtools/repo-cli/src/scripts/assert-containerized-runtime.ts",
    "temporal:export-replay-fixtures": "pnpm dar replay export",
    "temporal:export-evaluation-replay-fixtures": "TEMPORAL_REPLAY_SMOKE_RESULT_FILE=artifacts/evaluation-backend-e2e/framework.json pnpm dar replay export"
  },
  "devDependencies": {
    "@dar/config": "workspace:*",
    "@dar/contracts": "workspace:*",
    "@dar/db": "workspace:*",
    "@dar/i18n": "workspace:*",
    "@dar/model-client": "workspace:*",
    "@temporalio/client": "^1.11.0",
    "@temporalio/worker": "^1.11.0",
    "@eslint/js": "^9.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.0.0",
    "eslint": "^9.0.0",
    "pg": "^8.0.0",
    "pnpm": "10.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "turbo": "^2.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
